---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import Button from '../components/Button.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Evani Community - Komunitas NPC & Cosplayer" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Evani Community</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Rampart+One&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-surface border-b border-border py-4 px-6 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="/" class="flex items-center gap-2 overflow-visible">
          <!-- Logo for Light Mode -->
          <img src="/logo-light.png" alt="Evani Logo" class="h-20 w-auto block dark:hidden scale-150 origin-left object-contain" />
          <!-- Logo for Dark Mode -->
          <img src="/logo-dark.png" alt="Evani Logo" class="h-20 w-auto hidden dark:block scale-150 origin-left object-contain" />
        </a>
        <nav class="flex gap-6 items-center">
          <a href="/events" class="hover:text-content transition-colors font-medium">Kegiatan</a>
          <a href="/articles" class="hover:text-content transition-colors font-medium">Artikel</a>
          <ThemeToggle />
        </nav>
      </div>
    </header>
    
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Global CTA Section -->
    <section class="bg-primary/10 border-t border-primary/20 py-16 text-center">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-display mb-4">Tertarik Bergabung Bersama Evani?</h2>
        <p class="text-lg text-muted mb-8 font-body">Jangan ragu, gabung ke Discord atau WhatsApp kami sekarang juga! Semua orang diterima dengan tangan terbuka, baik kamu seorang wibu veteran maupun pemula yang sekadar ingin kumpul bareng.</p>
        <Button href="#" variant="primary">Join Komunitas Evani</Button>
      </div>
    </section>

    <footer class="bg-surface border-t border-border py-8 text-center text-muted">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p>&copy; {new Date().getFullYear()} Evani Community. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="https://instagram.com/evani" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
            Instagram Evani
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark'; // Default to dark theme as requested
      })();
    
      if (theme === 'light') {
        document.documentElement.classList.add('light');
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
        document.documentElement.classList.remove('light');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </body>
</html>
