---
import '../styles/global.css';
import Button from '../components/Button.astro';

interface Props {
  title: string;
  isHome?: boolean;
}

const { title, isHome = false } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Evani Community - Komunitas NPC & Cosplayer" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Evani Community</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Rampart+One&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col relative">
    <!-- Seamless Global Background -->
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
      {isHome ? (
        <Fragment>
          <!-- Left side (Light/White) -->
          <div class="absolute inset-0 w-full h-full bg-white opacity-95"></div>
          <img src="/pattern.png" alt="" class="absolute inset-0 w-full h-full object-cover opacity-[0.02] grayscale" />
          
          <!-- Right side (Red) with Diagonal Cut (Seamless across whole page) -->
          <div class="absolute top-0 right-0 w-full md:w-[45%] h-full bg-primary/50 hidden md:block" style="clip-path: polygon(60% 0, 100% 0, 100% 100%, 0% 100%);">
          </div>
          <!-- Untuk mobile -->
          <div class="absolute bottom-0 right-0 w-full h-[40%] bg-primary/50 md:hidden" style="clip-path: polygon(0 60%, 100% 0, 100% 100%, 0% 100%);">
          </div>

          <!-- Decorative Blobs -->
          <!-- Top Left Ambient Glow -->
          <div class="absolute top-[10%] left-[-10%] w-[40rem] h-[40rem] bg-primary/20 rounded-full mix-blend-multiply filter blur-[120px] opacity-80 animate-pulse hidden md:block"></div>
          <!-- Bottom Left Ambient Glow -->
          <div class="absolute bottom-[10%] left-[5%] w-[45rem] h-[45rem] bg-primary/10 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-pulse hidden md:block" style="animation-delay: 1s;"></div>
          
          <!-- Mobile Blob -->
          <div class="absolute top-[20%] left-[-5%] w-[30rem] h-[30rem] bg-primary/20 rounded-full mix-blend-multiply filter blur-[100px] opacity-70 animate-pulse md:hidden"></div>

          <!-- Right Overlay Glow -->
          <div class="absolute bottom-[20%] right-[10%] w-[40rem] h-[40rem] bg-white/20 rounded-full mix-blend-overlay filter blur-[120px] opacity-60 animate-pulse" style="animation-delay: 2s;"></div>
        </Fragment>
      ) : (
        <Fragment>
          <!-- Gradient Background for Non-Home Pages -->
          <div class="absolute inset-0 w-full h-full bg-gradient-to-br from-white via-red-50 to-red-100"></div>
          <img src="/pattern.png" alt="" class="absolute inset-0 w-full h-full object-cover opacity-[0.03] grayscale mix-blend-multiply" />
          
          <!-- Decorative Blobs -->
          <div class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-primary/10 rounded-full mix-blend-multiply filter blur-[100px] opacity-70"></div>
          <div class="absolute bottom-[-10%] right-[-10%] w-[40rem] h-[40rem] bg-rose-300/20 rounded-full mix-blend-multiply filter blur-[120px] opacity-60"></div>
        </Fragment>
      )}
    </div>
    <!-- Floating Pill Header -->
    <div class="fixed w-full top-6 z-50 flex justify-center px-6 pointer-events-none">
      <header id="main-header" class="pointer-events-auto relative w-full max-w-7xl transition-all duration-300 py-3 px-6 md:px-8 bg-white/70 backdrop-blur-xl border border-white/60 rounded-full shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex justify-between items-center">
        
        <!-- Left: Logo -->
        <a href="/" class="flex items-center gap-2 relative z-10">
          <img id="header-logo" src="/logo-light.png" alt="Evani Logo" class="h-8 md:h-10 w-auto origin-left object-contain transition-all duration-300 drop-shadow-sm" />
        </a>
        
        <!-- Center: Nav Links -->
        <nav class="hidden md:flex gap-8 items-center absolute left-1/2 -translate-x-1/2">
          <a href="/events" class="text-content/80 hover:text-primary transition-colors text-sm font-medium tracking-wide">Kegiatan</a>
          <a href="/articles" class="text-content/80 hover:text-primary transition-colors text-sm font-medium tracking-wide">Artikel</a>
        </nav>

        <!-- Right: Actions -->
        <div class="flex items-center gap-4 relative z-10">
          <a href="https://chat.whatsapp.com/JcXquYa6Nz3J9H53y0NAJA" class="hidden md:block text-xs font-bold bg-primary text-white px-5 py-2.5 rounded-full hover:bg-primary-hover transition-colors shadow-md shadow-primary/30">Join</a>
          
          <!-- Hamburger Button for Mobile -->
          <button id="mobile-menu-btn" class="md:hidden text-content p-2 focus:outline-none hover:bg-black/5 rounded-full transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu Dropdown -->
        <div id="mobile-menu" class="absolute top-[120%] left-0 right-0 bg-white/95 backdrop-blur-2xl border border-white/60 rounded-3xl p-6 shadow-2xl flex flex-col gap-4 origin-top scale-95 opacity-0 pointer-events-none transition-all duration-300 md:hidden">
          <a href="/events" class="text-content font-bold text-lg border-b border-gray-100 pb-3 mt-2">Kegiatan</a>
          <a href="/articles" class="text-content font-bold text-lg border-b border-gray-100 pb-3">Artikel</a>
          <a href="https://chat.whatsapp.com/JcXquYa6Nz3J9H53y0NAJA" class="text-center font-bold bg-primary text-white py-3 mt-4 rounded-full hover:bg-primary-hover transition-colors shadow-md shadow-primary/30">Join Komunitas</a>
        </div>
      </header>
    </div>
    
    <main class="flex-grow pt-24 md:pt-28">
      <slot />
    </main>

    <!-- Global CTA Section -->
    <section class="py-20 relative overflow-hidden bg-transparent">
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <div class="backdrop-blur-2xl bg-white/30 border border-white/60 rounded-[3rem] p-10 md:p-16 text-center shadow-[0_20px_50px_-15px_rgba(0,0,0,0.1)] relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-t from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <h2 class="text-3xl md:text-5xl font-display mb-6 text-content relative z-10">Tertarik Bergabung Bersama <span class="text-primary">Evani</span>?</h2>
          <p class="text-lg text-muted mb-10 font-body max-w-2xl mx-auto relative z-10">Jangan ragu, gabung ke Discord atau WhatsApp kami sekarang juga! Semua orang diterima dengan tangan terbuka, baik kamu seorang wibu veteran maupun pemula yang sekadar ingin kumpul bareng.</p>
          <Button href="https://chat.whatsapp.com/JcXquYa6Nz3J9H53y0NAJA" variant="primary" class="!rounded-full px-10 py-4 shadow-lg shadow-primary/30 text-lg transition-transform hover:-translate-y-1 relative z-10 inline-flex items-center justify-center">Join Komunitas Evani</Button>
        </div>
      </div>
    </section>

    <footer class="bg-white/40 backdrop-blur-md border-t border-white/40 py-8 relative z-10 shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-content font-medium">&copy; {new Date().getFullYear()} Evani Community. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/evani_community/" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors flex items-center gap-2 font-medium bg-white/50 px-4 py-2 rounded-full border border-white/60 hover:shadow-md hover:-translate-y-1">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
            @evani_community
          </a>
        </div>
      </div>
    </footer>

    <script>
      const header = document.getElementById('main-header');
      const logo = document.getElementById('header-logo');
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      
      // Scroll behavior
      window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
          header.classList.remove('py-3');
          header.classList.add('py-2', 'bg-white/95');
          logo.classList.remove('h-8', 'md:h-10');
          logo.classList.add('h-6', 'md:h-8');
        } else {
          header.classList.add('py-3');
          header.classList.remove('py-2', 'bg-white/95');
          logo.classList.add('h-8', 'md:h-10');
          logo.classList.remove('h-6', 'md:h-8');
        }
      });

      // Mobile Menu Toggle
      let isMenuOpen = false;
      if (mobileBtn) {
        mobileBtn.addEventListener('click', () => {
          isMenuOpen = !isMenuOpen;
          if (isMenuOpen) {
            mobileMenu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
            mobileMenu.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          } else {
            mobileMenu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
            mobileMenu.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>
