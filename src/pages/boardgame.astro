---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout title="Board Game | Evani Community">
  <section class="py-20 lg:py-32 bg-transparent relative overflow-hidden min-h-[70vh] flex items-center">
    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center w-full">
      <div class="backdrop-blur-2xl bg-white/40 border border-white/60 rounded-[3rem] p-10 md:p-16 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.1)] relative">
        <Breadcrumb items={[{ label: 'Beranda', href: '/' }, { label: 'Kegiatan', href: '/events' }, { label: 'Board Game' }]} class="mb-8 justify-center" />
        <div class="w-40 h-40 mx-auto mb-8 bg-white/50 rounded-full flex items-center justify-center p-6 border border-white/80 shadow-inner">
          <img src="/boardgame.png" alt="Board Game" class="w-full h-full object-contain drop-shadow-lg" />
        </div>
        <h1 class="text-4xl md:text-6xl font-display mb-6 text-content">Hayuk Kita Main!</h1>
        <p class="text-lg text-muted mb-10 font-body">Bosan main game digital? Saatnya tatap muka dan adu taktik! Dari permainan kartu, Uno, Monopoli, hingga aneka Board Game strategi tingkat tinggi.</p>
        <div class="flex gap-4 justify-center">
          <Button href="/events" variant="primary" class="!rounded-full px-10 py-4 shadow-lg shadow-primary/20 text-lg transition-transform hover:-translate-y-1">Lihat Jadwal Main</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
