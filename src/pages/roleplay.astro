---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Role-Play | Evani Community">
  <section class="py-20 lg:py-32 bg-base relative overflow-hidden min-h-[70vh] flex items-center">
    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
      <div class="w-40 h-40 mx-auto mb-8 bg-primary/10 rounded-full flex items-center justify-center p-6">
        <img src="/roleplay.png" alt="Role-Play" class="w-full h-full object-contain drop-shadow-lg" />
      </div>
      <h1 class="text-4xl md:text-6xl font-display mb-6">Hayuk Kita Role-Play!</h1>
      <p class="text-lg text-muted mb-10">Selami dunia imajinasi tanpa batas. Mari bertualang bersama di ranah Dungeons & Dragons dan aneka Tabletop RPG seru lainnya. Siapkan dadumu, tentukan nasib karaktermu, dan mari buat cerita legendaris bersama!</p>
      <div class="flex gap-4 justify-center">
        <Button href="/" variant="outline">Kembali</Button>
        <Button href="/events" variant="primary">Lihat Jadwal Main</Button>
      </div>
    </div>
  </section>
</BaseLayout>
