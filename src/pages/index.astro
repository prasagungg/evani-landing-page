---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Beranda" isHome={true}>
  <!-- NEW HERO SECTION -->
  <section class="relative bg-transparent overflow-hidden min-h-[90vh] flex items-center py-20">

    <div class="max-w-7xl mx-auto px-6 relative z-10 w-full flex flex-col md:flex-row items-center justify-between gap-12">
      
      <!-- Left: Glassmorphism Card -->
      <div class="w-full md:w-5/12 relative z-20">
        <div class="backdrop-blur-xl bg-white/40 border border-white/60 p-8 md:p-10 rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] relative">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-display text-content mb-2">
            Evani <span class="text-primary">Community</span>
          </h1>
          <div class="text-primary font-bold tracking-widest text-xs md:text-sm uppercase mb-6 flex items-center gap-2">
            <span class="w-8 h-0.5 bg-primary inline-block"></span> Komunitas NPC & Cosplayer
          </div>
          <p class="text-muted font-body mb-8 leading-relaxed">
            Wadah berkreasi yang mendukung talenta lokal dan merayakan budaya pop Jepang.
            Bersama kita membangun komunitas yang inklusif, berani, dan energetik.
          </p>
          <div class="flex gap-4">
            <Button href="/events" variant="primary" class="!rounded-full px-8 py-3 shadow-lg shadow-primary/30">Join Sekarang</Button>
          </div>
          
          <!-- Decorative Badge -->
          <div class="absolute -bottom-6 -right-6 md:-bottom-8 md:-right-8 w-20 h-20 md:w-24 md:h-24 bg-primary/90 backdrop-blur-md rounded-full flex flex-col items-center justify-center text-white font-display shadow-xl border-4 border-white/50">
            <span class="text-sm md:text-base leading-none">Est.</span>
            <span class="text-xl md:text-2xl leading-none">2024</span>
          </div>
        </div>
      </div>

      <!-- Right: Image / Characters -->
      <div class="w-full md:w-7/12 relative z-10 flex justify-center md:justify-end mt-10 md:mt-0">
         <img src="/hero.png" alt="Evani Hero" class="w-full h-auto max-w-2xl object-contain drop-shadow-2xl z-20" />
      </div>
      
    </div>
  </section>

  <!-- Activities Section -->
  <section class="py-20 bg-transparent relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-display text-content">Ada apa di Evani?</h2>
        <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full"></div>
      </div>
      
      <div class="flex flex-wrap justify-center gap-6">
        <!-- Card 1 -->
        <a href="/roleplay" class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] group backdrop-blur-2xl bg-white/20 rounded-3xl border border-white/70 hover:bg-white/40 hover:border-white p-6 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] hover:-translate-y-2 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-32 h-32 mb-6 bg-white/40 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 p-2 border border-white/80 shadow-inner relative z-10">
            <img src="/roleplay.png" alt="Role-Play" class="w-full h-full object-cover rounded-full" />
          </div>
          <h3 class="text-xl font-bold mb-2 font-display text-content group-hover:text-primary transition-colors relative z-10">Role-Play</h3>
          <p class="text-muted text-sm relative z-10">"Hayuk Kita Role-Play!" Selami dunia imajinasi D&D dan berbagai RPG seru lainnya.</p>
        </a>

        <!-- Card 2 -->
        <a href="/game" class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] group backdrop-blur-2xl bg-white/20 rounded-3xl border border-white/70 hover:bg-white/40 hover:border-white p-6 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] hover:-translate-y-2 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-32 h-32 mb-6 bg-white/40 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 p-2 border border-white/80 shadow-inner relative z-10">
            <img src="/game.png" alt="Nge-Game" class="w-full h-full object-cover rounded-full" />
          </div>
          <h3 class="text-xl font-bold mb-2 font-display text-content group-hover:text-primary transition-colors relative z-10">Gaming</h3>
          <p class="text-muted text-sm relative z-10">"Hayuk Kita Nge-Game!" Mabar game favoritmu bersama teman-teman sehobi.</p>
        </a>

        <!-- Card 3 -->
        <a href="/futsal" class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] group backdrop-blur-2xl bg-white/20 rounded-3xl border border-white/70 hover:bg-white/40 hover:border-white p-6 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] hover:-translate-y-2 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-32 h-32 mb-6 bg-white/40 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 p-2 border border-white/80 shadow-inner relative z-10">
            <img src="/futsal.png" alt="Futsal" class="w-full h-full object-cover rounded-full" />
          </div>
          <h3 class="text-xl font-bold mb-2 font-display text-content group-hover:text-primary transition-colors relative z-10">Futsal</h3>
          <p class="text-muted text-sm relative z-10">"Hayuk Kita Futsal!" Asah kelincahan dan kerja sama tim di lapangan futsal.</p>
        </a>

        <!-- Card 4 -->
        <a href="/badminton" class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] group backdrop-blur-2xl bg-white/20 rounded-3xl border border-white/70 hover:bg-white/40 hover:border-white p-6 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] hover:-translate-y-2 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-32 h-32 mb-6 bg-white/40 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 p-2 border border-white/80 shadow-inner relative z-10">
            <img src="/badminton.png" alt="Badminton" class="w-full h-full object-cover rounded-full" />
          </div>
          <h3 class="text-xl font-bold mb-2 font-display text-content group-hover:text-primary transition-colors relative z-10">Badminton</h3>
          <p class="text-muted text-sm relative z-10">"Hayuk Kita Badminton!" Cari keringat sehat lewat olahraga bulu tangkis santai.</p>
        </a>

        <!-- Card 5 -->
        <a href="/boardgame" class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] group backdrop-blur-2xl bg-white/20 rounded-3xl border border-white/70 hover:bg-white/40 hover:border-white p-6 transition-all shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] hover:-translate-y-2 flex flex-col items-center text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-32 h-32 mb-6 bg-white/40 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 p-2 border border-white/80 shadow-inner relative z-10">
            <img src="/boardgame.png" alt="Main Boardgame" class="w-full h-full object-cover rounded-full" />
          </div>
          <h3 class="text-xl font-bold mb-2 font-display text-content group-hover:text-primary transition-colors relative z-10">Board Game</h3>
          <p class="text-muted text-sm relative z-10">"Hayuk Kita Main!" Habiskan waktu seru dengan adu taktik di aneka permainan kartu dan board game.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Kegiatan Terbaru -->
  <section class="py-20 bg-transparent relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="flex justify-between items-end mb-10">
        <div class="flex items-center gap-4 flex-grow">
          <h2 class="text-3xl font-display text-content">Kegiatan Terbaru</h2>
          <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full max-w-sm"></div>
        </div>
        <a href="/events" class="text-primary hover:text-primary-hover transition-colors font-medium text-sm ml-4 hidden md:block">Lihat Semua &rarr;</a>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Mock Event Card 1 -->
        <a href="/events" class="group backdrop-blur-xl bg-white/40 rounded-2xl border border-white/60 overflow-hidden hover:bg-white/60 hover:border-primary hover:shadow-2xl transition-all flex flex-col shadow-xl">
          <div class="h-56 bg-white/30 relative flex items-center justify-center border-b border-white/40">
            <div class="absolute top-4 left-4 backdrop-blur-md bg-primary/90 text-white px-3 py-1.5 rounded-lg text-sm font-bold shadow-md z-10 border border-primary-hover">24 Jun</div>
            <img src="/roleplay.png" alt="D&D Night" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
          </div>
          <div class="p-6 flex-grow flex flex-col">
            <span class="text-xs font-bold text-primary tracking-wider uppercase mb-2 block">Role-Play</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors">D&D One-Shot: The Red Dragon</h3>
            <p class="text-muted text-sm mb-6 flex-grow">Sesi singkat D&D untuk pemula. Bawa dadu kalian dan bersiap melawan naga merah legendaris!</p>
            <span class="text-primary text-sm font-medium inline-flex items-center gap-1 group-hover:translate-x-2 transition-transform">Baca Detail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg></span>
          </div>
        </a>
        
        <!-- Mock Event Card 2 -->
        <a href="/events" class="group backdrop-blur-xl bg-white/40 rounded-2xl border border-white/60 overflow-hidden hover:bg-white/60 hover:border-primary hover:shadow-2xl transition-all flex flex-col shadow-xl">
          <div class="h-56 bg-white/30 relative flex items-center justify-center border-b border-white/40">
            <div class="absolute top-4 left-4 backdrop-blur-md bg-primary/90 text-white px-3 py-1.5 rounded-lg text-sm font-bold shadow-md z-10 border border-primary-hover">28 Jun</div>
            <img src="/futsal.png" alt="Futsal Bareng" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
          </div>
          <div class="p-6 flex-grow flex flex-col">
            <span class="text-xs font-bold text-primary tracking-wider uppercase mb-2 block">Futsal</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors">Futsal Komunitas #12</h3>
            <p class="text-muted text-sm mb-6 flex-grow">Mabar lapangan hijau rutin hari jumat. Patungan 20k per orang, wajib bawa sepatu karet.</p>
            <span class="text-primary text-sm font-medium inline-flex items-center gap-1 group-hover:translate-x-2 transition-transform">Baca Detail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg></span>
          </div>
        </a>
        
        <!-- Mock Event Card 3 -->
        <a href="/events" class="group backdrop-blur-xl bg-white/40 rounded-2xl border border-white/60 overflow-hidden hover:bg-white/60 hover:border-primary hover:shadow-2xl transition-all flex flex-col shadow-xl">
          <div class="h-56 bg-white/30 relative flex items-center justify-center border-b border-white/40">
            <div class="absolute top-4 left-4 backdrop-blur-md bg-primary/90 text-white px-3 py-1.5 rounded-lg text-sm font-bold shadow-md z-10 border border-primary-hover">02 Jul</div>
            <img src="/boardgame.png" alt="Boardgame" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
          </div>
          <div class="p-6 flex-grow flex flex-col">
            <span class="text-xs font-bold text-primary tracking-wider uppercase mb-2 block">Board Game</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors">Pesta Monopoli & Uno</h3>
            <p class="text-muted text-sm mb-6 flex-grow">Kumpul santai sambil main Monopoli dan Uno. Yang kalah wajib traktir minuman!</p>
            <span class="text-primary text-sm font-medium inline-flex items-center gap-1 group-hover:translate-x-2 transition-transform">Baca Detail <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg></span>
          </div>
        </a>
      </div>
      <a href="/events" class="text-primary font-medium text-sm mt-8 block text-center md:hidden">Lihat Semua Kegiatan &rarr;</a>
    </div>
  </section>

  <!-- Artikel Terbaru -->
  <section class="py-20 bg-transparent relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="flex justify-between items-end mb-10">
        <div class="flex items-center gap-4 flex-grow">
          <h2 class="text-3xl font-display text-content">Artikel Terbaru</h2>
          <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full max-w-sm"></div>
        </div>
        <a href="/articles" class="text-primary hover:text-primary-hover transition-colors font-medium text-sm ml-4 hidden md:block">Lihat Semua &rarr;</a>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Mock Article 1 -->
        <a href="/articles" class="group flex flex-col sm:flex-row gap-6 backdrop-blur-xl bg-white/40 p-6 rounded-2xl border border-white/60 hover:bg-white/60 hover:border-primary transition-all shadow-xl hover:shadow-2xl">
          <div class="w-full sm:w-48 h-48 sm:h-auto bg-white/30 rounded-xl overflow-hidden flex-shrink-0 relative border border-white/40">
            <img src="/game.png" alt="Tips Gaming" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
          </div>
          <div class="flex flex-col justify-center py-2">
            <span class="text-xs text-primary font-bold tracking-wider uppercase mb-2">Tutorial & Tips</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors line-clamp-2">Tips Push Rank Mobile Legends Cepat ke Mythic</h3>
            <p class="text-muted text-sm line-clamp-3 mb-4">Bosan stuck di Epic atau Legend? Coba terapkan tips drafting dan rotasi berikut ini agar cepat sampai ke Mythic.</p>
            <span class="text-primary text-sm font-medium mt-auto inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">Baca <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
          </div>
        </a>
        
        <!-- Mock Article 2 -->
        <a href="/articles" class="group flex flex-col sm:flex-row gap-6 backdrop-blur-xl bg-white/40 p-6 rounded-2xl border border-white/60 hover:bg-white/60 hover:border-primary transition-all shadow-xl hover:shadow-2xl">
          <div class="w-full sm:w-48 h-48 sm:h-auto bg-white/30 rounded-xl overflow-hidden flex-shrink-0 relative border border-white/40">
            <img src="/badminton.png" alt="Tips Badminton" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
          </div>
          <div class="flex flex-col justify-center py-2">
            <span class="text-xs text-primary font-bold tracking-wider uppercase mb-2">Gaya Hidup</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors line-clamp-2">Cara Memilih Raket Badminton untuk Pemula</h3>
            <p class="text-muted text-sm line-clamp-3 mb-4">Bingung memilih raket yang pas? Jangan sampai salah beli. Pahami perbedaan berat dan tarikan senar raket yang cocok untukmu.</p>
            <span class="text-primary text-sm font-medium mt-auto inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">Baca <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
          </div>
        </a>
      </div>
      <a href="/articles" class="text-primary font-medium text-sm mt-8 block text-center md:hidden">Lihat Semua Artikel &rarr;</a>
    </div>
  </section>
</BaseLayout>

