---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';

const allEvents = await getCollection('events');
const sortedEvents = allEvents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Daftar Kegiatan">
  <div class="max-w-6xl mx-auto px-6 py-12 relative z-10">
    <div class="flex items-center gap-4 mb-10">
      <h1 class="text-4xl font-display text-content">Semua Kegiatan</h1>
      <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedEvents.map(event => (
        <Card 
          type="event"
          title={event.data.title}
          href={`/events/${event.id}`}
          image={event.data.coverImage}
          date={event.data.date}
          location={event.data.location}
          tags={event.data.tags}
        />
      ))}
    </div>
    
    {sortedEvents.length === 0 && (
      <p class="text-center text-muted py-12">Belum ada kegiatan saat ini.</p>
    )}
  </div>
</BaseLayout>
