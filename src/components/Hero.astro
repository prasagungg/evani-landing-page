---
import Button from './Button.astro';
---

<!-- NEW HERO SECTION -->
<section class="relative bg-transparent overflow-hidden min-h-[90vh] flex items-center py-20">

  <div class="max-w-7xl mx-auto px-6 relative z-10 w-full flex flex-col md:flex-row items-center justify-between gap-12">
    
    <!-- Left: Glassmorphism Card -->
    <div class="w-full md:w-5/12 relative z-20">
      <div class="backdrop-blur-xl bg-white/40 border border-white/60 p-8 md:p-10 rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] relative">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display text-content mb-2">
          Evani <span class="text-primary">Community</span>
        </h1>
        <div class="text-primary font-bold tracking-widest text-xs md:text-sm uppercase mb-6 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-primary inline-block"></span> Komunitas NPC & Cosplayer
        </div>
        <p class="text-muted font-body mb-8 leading-relaxed">
          Wadah berkreasi yang mendukung talenta lokal dan merayakan budaya pop Jepang.
          Bersama kita membangun komunitas yang inklusif, berani, dan energetik.
        </p>
        <div class="flex gap-4">
          <Button href="https://chat.whatsapp.com/JcXquYa6Nz3J9H53y0NAJA" variant="primary" class="!rounded-full px-8 py-3 shadow-lg shadow-primary/30">Join Sekarang</Button>
        </div>
        
        <!-- Decorative Badge -->
        <div class="absolute -bottom-6 -right-6 md:-bottom-8 md:-right-8 w-20 h-20 md:w-24 md:h-24 bg-primary/90 backdrop-blur-md rounded-full flex flex-col items-center justify-center text-white font-display shadow-xl border-4 border-white/50">
          <span class="text-sm md:text-base leading-none">Est.</span>
          <span class="text-xl md:text-2xl leading-none">2024</span>
        </div>
      </div>
    </div>

    <!-- Right: Image / Characters -->
    <div class="w-full md:w-7/12 relative z-10 flex justify-center md:justify-end mt-10 md:mt-0">
        <img src="/hero.png" alt="Evani Hero" class="w-full h-auto max-w-2xl object-contain drop-shadow-2xl z-20" />
    </div>
    
  </div>
</section>
