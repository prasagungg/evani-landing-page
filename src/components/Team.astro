---
---

<!-- Community Figures Section (No Admin Labels) -->
<section class="py-20 bg-transparent relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="flex flex-col items-center text-center mb-16">
      <h2 class="text-3xl font-display text-content mb-4">Kenalan Yuk!</h2>
      <div class="h-1 w-24 bg-primary/40 rounded-full mb-6"></div>
      <p class="text-muted max-w-2xl text-lg font-body">
        Mereka yang selalu siap menyambut hangat, menemani keseruan event, dan mendengarkan setiap ceritamu di komunitas. Jangan ragu buat sapa duluan ya!
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <!-- Zoon / Jun -->
      <div class="group flex flex-col items-center">
        <div class="w-56 h-56 mb-6 rounded-3xl backdrop-blur-xl bg-white/40 border-2 border-white/60 p-3 shadow-xl group-hover:border-primary group-hover:-translate-y-2 transition-all duration-300">
          <div class="w-full h-full rounded-2xl bg-white/50 overflow-hidden relative">
            <!-- Placeholder: Replace with actual image -->
            <img src="/jun.png" alt="Jun" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
          </div>
        </div>
        <h3 class="text-2xl font-display font-bold text-content group-hover:text-primary transition-colors">Jun</h3>
        <p class="text-content/80 font-medium text-sm mt-1">Si Mantan Gondrong</p>
      </div>

      <!-- Jula -->
      <div class="group flex flex-col items-center">
        <div class="w-56 h-56 mb-6 rounded-3xl backdrop-blur-xl bg-white/40 border-2 border-white/60 p-3 shadow-xl group-hover:border-primary group-hover:-translate-y-2 transition-all duration-300 md:-translate-y-6">
          <div class="w-full h-full rounded-2xl bg-white/50 overflow-hidden relative">
            <!-- Placeholder: Replace with actual image -->
            <img src="/jula.png" alt="Jula" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
          </div>
        </div>
        <h3 class="text-2xl font-display font-bold text-content group-hover:text-primary transition-colors md:-translate-y-6">Jula</h3>
        <p class="text-content/80 font-medium text-sm mt-1 md:-translate-y-6">Si Tukang Misuh</p>
      </div>

      <!-- Indra -->
      <div class="group flex flex-col items-center">
        <div class="w-56 h-56 mb-6 rounded-3xl backdrop-blur-xl bg-white/40 border-2 border-white/60 p-3 shadow-xl group-hover:border-primary group-hover:-translate-y-2 transition-all duration-300">
          <div class="w-full h-full rounded-2xl bg-white/50 overflow-hidden relative">
            <!-- Placeholder: Replace with actual image -->
            <img src="/indra.png" alt="Indra" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
          </div>
        </div>
        <h3 class="text-2xl font-display font-bold text-content group-hover:text-primary transition-colors">Indra</h3>
        <p class="text-content/80 font-medium text-sm mt-1">Si Tukang Troll</p>
      </div>
    </div>
  </div>
</section>
