---
import { getCollection } from 'astro:content';
import Card from './Card.astro';

const allEvents = await getCollection('events');
const latestEvents = allEvents
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<!-- Kegiatan Terbaru -->
<section class="py-20 bg-transparent relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="flex justify-between items-end mb-10">
      <div class="flex items-center gap-4 flex-grow">
        <h2 class="text-3xl font-display text-content">Kegiatan Terbaru</h2>
        <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full max-w-sm"></div>
      </div>
      <a href="/events" class="text-primary hover:text-primary-hover transition-colors font-medium text-sm ml-4 hidden md:block">Lihat Semua &rarr;</a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestEvents.map(event => (
        <Card 
          type="event"
          title={event.data.title}
          href={`/events/${event.id}`}
          image={event.data.coverImage}
          date={event.data.date}
          location={event.data.location}
          tags={event.data.tags}
        />
      ))}
      
      {latestEvents.length === 0 && (
        <div class="col-span-3 text-center text-muted py-10">Belum ada kegiatan yang dijadwalkan.</div>
      )}
    </div>
    <a href="/events" class="text-primary font-medium text-sm mt-8 block text-center md:hidden">Lihat Semua Kegiatan &rarr;</a>
  </div>
</section>
