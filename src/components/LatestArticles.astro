---
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<!-- Artikel Terbaru -->
<section class="py-20 bg-transparent relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="flex justify-between items-end mb-10">
      <div class="flex items-center gap-4 flex-grow">
        <h2 class="text-3xl font-display text-content">Artikel Terbaru</h2>
        <div class="h-1 flex-grow bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full max-w-sm"></div>
      </div>
      <a href="/articles" class="text-primary hover:text-primary-hover transition-colors font-medium text-sm ml-4 hidden md:block">Lihat Semua &rarr;</a>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      {latestArticles.map(article => (
        <a href={`/articles/${article.id}`} class="group flex flex-col sm:flex-row gap-6 backdrop-blur-xl bg-white/40 p-6 rounded-2xl border border-white/60 hover:bg-white/50 hover:border-primary transition-all shadow-xl hover:shadow-2xl">
          <div class="w-full sm:w-48 h-48 sm:h-auto bg-white/30 rounded-xl overflow-hidden flex-shrink-0 relative border border-white/40">
            {article.data.coverImage ? (
              <img src={article.data.coverImage} alt={article.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90" />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gray-100">
                <span class="text-gray-400">No Image</span>
              </div>
            )}
          </div>
          <div class="flex flex-col justify-center py-2">
            <span class="text-xs text-primary font-bold tracking-wider uppercase mb-2">Artikel</span>
            <h3 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors line-clamp-2">{article.data.title}</h3>
            <p class="text-muted text-sm line-clamp-3 mb-4">{article.body?.slice(0, 120).replace(/#/g, '')}...</p>
            <span class="text-primary text-sm font-medium mt-auto inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">Baca <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
          </div>
        </a>
      ))}
      
      {latestArticles.length === 0 && (
        <div class="col-span-2 text-center text-muted py-10">Belum ada artikel yang dipublikasikan.</div>
      )}
    </div>
    <a href="/articles" class="text-primary font-medium text-sm mt-8 block text-center md:hidden">Lihat Semua Artikel &rarr;</a>
  </div>
</section>
