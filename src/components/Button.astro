---
import type { HTMLAttributes } from 'astro/types';

interface Props {
  href?: string;
  variant?: 'primary' | 'outline';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  target?: string;
  [key: string]: any;
}

const { href, variant = 'primary', class: className = '', type = 'button', target, ...rest } = Astro.props;

// Primary: Background #BA121A, teks #FFFFFF (Poppins, Bold), bentuk slightly rounded. Hover: lebih terang
// Outline: Transparent background, border 2px solid #BA121A, teks #BA121A
const baseStyles = "inline-flex justify-center items-center px-6 py-2.5 font-body font-bold rounded text-sm transition-colors duration-200";

const variants = {
  primary: "bg-primary text-white hover:bg-primary-hover shadow-sm",
  outline: "bg-transparent border-2 border-primary text-primary hover:bg-primary/10"
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} target={target} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
