---
interface Props {
  title: string;
  href: string;
  image?: string;
  date?: Date;
  location?: string;
  author?: string;
  tags?: string[];
  type?: 'event' | 'article';
}

const { title, href, image, date, location, author, tags, type = 'event' } = Astro.props;

// Format date nicely
const formattedDate = date ? new Intl.DateTimeFormat('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(date) : null;
---

<a href={href} class="block group h-full">
  <article class="bg-surface rounded-md overflow-hidden border-b-4 border-primary shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 h-full flex flex-col">
    {image && (
      <div class="h-48 overflow-hidden bg-base relative">
        <img 
          src={image} 
          alt={title} 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
        />
        {type === 'event' && tags && tags.length > 0 && (
          <div class="absolute top-3 left-3 flex flex-wrap gap-1">
            <span class="text-[10px] font-bold bg-primary text-white px-2 py-1 rounded shadow-sm uppercase tracking-wider">
              {tags[0]}
            </span>
          </div>
        )}
      </div>
    )}
    <div class="p-5 flex-grow flex flex-col">
      <div class="flex items-center flex-wrap gap-x-4 gap-y-2 text-xs text-muted mb-3 font-medium">
        {formattedDate && (
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            {formattedDate}
          </span>
        )}
        {location && (
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {location}
          </span>
        )}
        {author && (
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {author}
          </span>
        )}
      </div>
      
      <h3 class="text-xl font-display text-content group-hover:text-primary transition-colors mt-1 line-clamp-2">
        {title}
      </h3>
    </div>
  </article>
</a>
